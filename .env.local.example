# inference_plane local environment overrides.
#
# Copy this file to .env.local (which is gitignored) and fill in the
# values you have. Anything left blank is fine; the control plane only
# reads what it needs for the deployment you're running.
#
#   cp .env.local.example .env.local
#
# Loaded by docker-compose via:
#   docker compose --env-file .env.local --env-file pinned-versions.env ...
# (or by direnv / your shell of choice for non-compose runs)

# ── This deployment ─────────────────────────────────────────────────
# Which provider+gpu_type+billing_mode is *this* control plane running on.
# These values label the cost metrics so the actual-spend panel reflects
# reality. Match a row in providers.yaml.
#
# Variable names follow viper's IPLANE_<DOTTED_KEY_FLATTENED> convention:
# 'deployment.provider' becomes IPLANE_DEPLOYMENT_PROVIDER, etc.
IPLANE_DEPLOYMENT_PROVIDER=runpod
IPLANE_DEPLOYMENT_GPU_TYPE=a10g
IPLANE_DEPLOYMENT_BILLING_MODE=metered_per_second
IPLANE_DEPLOYMENT_INSTANCE_ID=        # set per deployment, free-form

# ── Backend (vLLM) ──────────────────────────────────────────────────
# vLLM endpoint the control plane proxies to. Inside the docker-compose
# stack this is the service name; outside, set to the host:port.
# Only consumed when backend.engine=vllm; ignored by mock.
IPLANE_BACKEND_URL=http://vllm:8000

# ── OpenTelemetry ───────────────────────────────────────────────────
# Override to point at a hosted backend (Grafana Cloud OTLP, Honeycomb,
# Datadog OTLP). Default is the local otel-collector container.
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# ── Provider API keys (only needed for cmd/provision, not for v0.1) ─
# v0.1 assumes you've provisioned a GPU instance manually via the
# provider's UI. The keys below are for a future cmd/provision CLI
# that automates bring-up/shutdown.
RUNPOD_API_KEY=
LAMBDA_API_KEY=
VAST_API_KEY=
EQUINIX_AUTH_TOKEN=
EQUINIX_PROJECT_ID=
