# Pinned versions: model, inference engine, observability stack, control plane.
# Single source of truth for docker-compose interpolation and Makefile targets.
#
# KEEP IN SYNC WITH:
#   ../book/src/styles/pinned-versions.tex
#
# Run `make check-pins` from the book repo to detect drift.

# ── Model ────────────────────────────────────────────────────────
MODEL_FAMILY=Qwen
MODEL_ID=qwen3.5
MODEL_TAG=8b
MODEL_FULL=qwen3.5-8b
MODEL_DISPLAY="Qwen 3.5 8B"
MODEL_LICENSE="Apache 2.0"
MODEL_PARAMS=8.2B
MODEL_CONTEXT=32768
MODEL_HF_ID=Qwen/Qwen3.5-8B-Instruct

# ── Inference engine ─────────────────────────────────────────────
ENGINE_ID=vllm
ENGINE_VERSION=0.7.3
ENGINE_DISPLAY=vLLM
ENGINE_PORT=8000

# ── Observability stack ─────────────────────────────────────────
# Real pinned tags (Docker can't resolve globs). Bump as the upstream
# images release; check-pins keeps the book's prose in sync.
OTEL_COLLECTOR_VERSION=0.116.0
GRAFANA_VERSION=11.4.0
LOKI_VERSION=3.3.0
TEMPO_VERSION=2.7.0
MIMIR_VERSION=2.14.0

# ── Control plane ───────────────────────────────────────────────
# CP_VERSION and CP_BRANCH are branch-specific by design:
#   main         -> dev / main (always latest source on this branch)
#   release/vX.Y -> vX.Y.0 / release/vX.Y (locked to the chapter snapshot)
# check-pins skips these two; the book's \cpversion / \cpbranch always
# point at the release branch the chapter is paired with.
CP_VERSION=v0.1.0
CP_BRANCH=release/v0.1
CP_REPO=github.com/inference-book/inference-plane
