# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env files (.env.local holds user-specific secrets and overrides)
.env
.env.local

# Editor/IDE
# .idea/
# .vscode/

# Local build artifacts
/bin/
/dist/
/tmp/

# Stray `go build` artifacts: running `go build ./examples/...` from
# the repo root drops the resulting binary at the root, named after
# the example's directory. Match the existing examples explicitly so
# we don't accidentally ignore real source folders that share the
# layout (rare, but possible).
/01-end-to-end
/02-cli-end-to-end
/03-deploy-end-to-end

# Local observability data (mounted into Grafana stack containers)
/deploy/data/

# Local-only docker-compose overrides
docker-compose.override.yaml
deploy/docker-compose.override.yaml
